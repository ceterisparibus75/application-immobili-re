// ============================================================
// PHASE 9 — NOTIFICATIONS
// ============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum PlanId {
  STARTER
  PRO
  ENTERPRISE
}

enum NotificationType {
  BAIL_EXPIRING
  INVOICE_OVERDUE
  DIAGNOSTIC_EXPIRING
  PAYMENT_RECEIVED
  MAINTENANCE_COMPLETED
  DOCUMENT_SIGNED
  SEPA_PAYMENT_FAILED
  SEPA_PAYMENT_CONFIRMED
  INSURANCE_EXPIRING
  RENT_REVISION
  TICKET_CREATED
  TICKET_REPLY
  TICKET_STATUS_CHANGED
}

/// Notification in-app
model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  societyId String

  type    NotificationType
  title   String
  message String           @db.Text
  link    String? // URL de navigation
  isRead  Boolean          @default(false)
  readAt  DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@index([userId, societyId])
  @@index([userId, isRead])
  @@index([societyId])
  @@index([createdAt])
}

// ============================================================
// PHASE 10 — DATAROOMS
// ============================================================

/// Salle des données virtuelle — partage sécurisé de documents GED
model Dataroom {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  societyId   String
  createdBy   String?

  name          String
  description   String?   @db.Text
  /// Token public unique pour l'accès sans authentification
  shareToken    String    @unique @default(cuid())
  status        String    @default("BROUILLON")
  expiresAt     DateTime?
  accessCount     Int       @default(0)
  lastAccessedAt  DateTime?
  /// Mot de passe haché (optionnel, haché bcrypt) pour protéger l'accès, null = accès libre
  password      String?
  /// Email du bénéficiaire externe (notifié à chaque ajout de document)
  recipientEmail String?
  recipientName  String?
  purpose        String?

  society     Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  creator    User?              @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  documents   DataroomDocument[]
  accesses    DataroomAccess[]

  @@index([societyId])
  @@index([shareToken])
  @@index([expiresAt])
}

/// Document inclus dans une dataroom
model DataroomDocument {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  dataroomId String
  documentId String
  sortOrder  Int      @default(0)
  section    String?

  dataroom   Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([dataroomId, documentId])
  @@index([dataroomId])
}

/// Trace d'accès externe à une dataroom
model DataroomAccess {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  dataroomId  String
  ipAddress   String?
  userAgent   String?
  viewerEmail String?
  viewerName  String?

  dataroom    Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([dataroomId, createdAt])
}

// ============================================================
// PHASE 10 — MONETISATION : ABONNEMENTS STRIPE
// ============================================================

/// Abonnement Stripe lie a une societe
model Subscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societyId String  @unique
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  // Stripe (nullable pour les essais implicites sans passage par Stripe)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Plan
  planId PlanId             @default(STARTER)
  status SubscriptionStatus @default(TRIALING)

  // Periodes
  trialStart       DateTime?
  trialEnd         DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt           DateTime?
  canceledAt         DateTime?

  @@index([societyId])
  @@index([stripeCustomerId])
  @@index([status])
}

// ============================================================
// PHASE 11 — RAPPORTS CONSOLIDÉS ET ENVOI AUTOMATIQUE
// ============================================================

enum ReportFrequency {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
}

/// Planification d'envoi automatique de rapports consolidés
model ReportSchedule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societyId String
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  name        String           // Nom de la planification (ex: "Rapport trimestriel investisseurs")
  frequency   ReportFrequency
  reportTypes String[]         // Types de rapports inclus (ex: ["COMPTE_RENDU_GESTION", "ETAT_IMPAYES"])
  recipients  String[]         // Adresses email des destinataires

  isActive    Boolean  @default(true)

  // Suivi d'exécution
  lastSentAt  DateTime?
  nextRunAt   DateTime

  @@index([societyId])
  @@index([isActive, nextRunAt])
}

// ============================================================
// AVIS DE VALEUR IA — Évaluation immobilière par IA
// ============================================================

enum ValuationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum AiProvider {
  CLAUDE
  GEMINI
  MISTRAL
  OPENAI
}

/// Avis de valeur IA pour un immeuble
model PropertyValuation {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  buildingId String
  societyId  String

  // Métadonnées
  valuationDate DateTime        @default(now())
  status        ValuationStatus @default(DRAFT)
  createdBy     String // userId

  // Résultats synthétiques
  estimatedValueLow    Float? // Fourchette basse
  estimatedValueMid    Float? // Valeur retenue
  estimatedValueHigh   Float? // Fourchette haute
  estimatedRentalValue Float? // Valeur locative annuelle estimée
  pricePerSqm          Float? // Prix au m² retenu
  capitalizationRate   Float? // Taux de capitalisation retenu (%)

  // Relations
  building           Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  society            Society               @relation(fields: [societyId], references: [id], onDelete: Cascade)
  aiAnalyses         AiValuationAnalysis[]
  expertReports      ExpertReport[]
  comparableSales    ComparableSale[]
  consolidatedReport ConsolidatedReport?

  @@index([buildingId])
  @@index([societyId])
  @@index([societyId, buildingId])
}

/// Analyse IA individuelle (Claude ou Gemini)
model AiValuationAnalysis {
  id          String @id @default(cuid())
  valuationId String

  provider     AiProvider // CLAUDE, GEMINI
  modelVersion String // ex: "claude-sonnet-4-20250514", "gemini-2.0-flash"

  // Données d'entrée envoyées à l'IA
  inputPayload Json // Le JSON complet envoyé à l'IA

  // Résultat structuré de l'IA
  rawResponse      String @db.Text // Réponse brute
  structuredResult Json // Résultat parsé en JSON structuré

  // Valeurs extraites
  estimatedValue Float? // Valeur vénale estimée
  rentalValue    Float? // Valeur locative estimée
  pricePerSqm    Float? // Prix au m²
  capRate        Float? // Taux de capitalisation (%)
  methodology    String? @db.Text // Description de la méthode utilisée
  strengths      Json? // Points forts identifiés (string[])
  weaknesses     Json? // Points faibles identifiés (string[])
  opportunities  Json? // Opportunités identifiées (string[])
  threats        Json? // Menaces identifiées (string[])
  confidence     Float? // Score de confiance 0-1

  executedAt DateTime @default(now())
  durationMs Int? // Temps d'exécution en ms
  tokenCount Int? // Tokens consommés
  cost       Float? // Coût estimé en EUR

  valuation PropertyValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)

  @@index([valuationId])
}

/// Rapport d'expertise importé (PDF)
model ExpertReport {
  id          String @id @default(cuid())
  valuationId String

  // Métadonnées du rapport
  expertName      String // Nom de l'expert ou du cabinet
  reportDate      DateTime // Date du rapport
  reportReference String? // Référence du rapport

  // Fichier PDF source
  fileUrl  String // URL du fichier stocké (Supabase Storage)
  fileName String
  fileSize Int

  // Données extraites par IA du PDF
  extractedData Json // Données structurées extraites du rapport

  // Valeurs clés extraites
  estimatedValue Float? // Valeur vénale retenue par l'expert
  rentalValue    Float? // Valeur locative
  pricePerSqm    Float? // Prix au m²
  capRate        Float? // Taux de capitalisation (%)
  usableArea     Float? // Surface utile retenue
  methodology    String? @db.Text

  createdAt DateTime @default(now())

  valuation PropertyValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)

  @@index([valuationId])
}

/// Transaction comparable (DVF ou manuelle)
model ComparableSale {
  id          String @id @default(cuid())
  valuationId String

  // Source de la donnée
  source          String // "DVF", "MANUAL", "AI_SEARCH"
  sourceReference String? // Référence dans la source

  // Données de la transaction
  address    String
  city       String
  postalCode String
  saleDate   DateTime
  salePrice  Float
  builtArea  Float? // Surface bâtie (m²)
  landArea   Float? // Surface terrain (m²)
  pricePerSqm  Float?
  propertyType String // "BUREAUX", "HABITATION", "COMMERCIAL", "MIXTE"
  buildingAge  String? // "NEUF", "RECENT", "ANCIEN"
  distanceKm   Float? // Distance au bien évalué (km)

  // Pertinence
  relevanceScore   Float? // 0-1, calculé par l'IA
  relevanceComment String? @db.Text

  valuation PropertyValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)

  @@index([valuationId])
}

/// Rapport consolidé généré (PDF)
model ConsolidatedReport {
  id          String @id @default(cuid())
  valuationId String @unique

  // Fichier PDF généré
  fileUrl  String?
  fileName String?

  // Contenu structuré du rapport
  reportContent Json // Sections du rapport en JSON structuré

  generatedAt DateTime @default(now())
  generatedBy String // userId

  valuation PropertyValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)
}

// ============================================================
// ÉVALUATION DES LOYERS PAR IA — Module Baux
// ============================================================

enum RentValuationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

/// Évaluation de loyer par IA pour un bail
model RentValuation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leaseId   String
  societyId String

  // Métadonnées
  valuationDate DateTime            @default(now())
  status        RentValuationStatus @default(DRAFT)
  createdBy     String // userId

  // Résultats synthétiques
  currentRent          Float? // Loyer actuel du bail
  estimatedMarketRent  Float? // Loyer de marché estimé (annuel HT)
  estimatedRentLow     Float? // Fourchette basse
  estimatedRentHigh    Float? // Fourchette haute
  rentPerSqm           Float? // Loyer au m² retenu
  deviationPercent     Float? // Écart loyer actuel vs marché (%)

  // Relations
  lease              Lease                @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  society            Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  aiAnalyses         RentAiAnalysis[]
  comparableRents    ComparableRent[]
  consolidatedReport RentConsolidatedReport?

  @@index([leaseId])
  @@index([societyId])
  @@index([societyId, leaseId])
}

/// Analyse IA de loyer (Claude ou Gemini)
model RentAiAnalysis {
  id               String @id @default(cuid())
  rentValuationId  String

  provider     AiProvider
  modelVersion String

  inputPayload     Json
  rawResponse      String @db.Text
  structuredResult Json

  estimatedRent    Float? // Loyer de marché estimé
  rentPerSqm       Float? // Loyer au m²
  methodology      String? @db.Text
  strengths        Json? // string[]
  weaknesses       Json? // string[]
  opportunities    Json? // string[]
  threats          Json? // string[]
  confidence       Float? // Score de confiance 0-1

  executedAt DateTime @default(now())
  durationMs Int?
  tokenCount Int?
  cost       Float?

  rentValuation RentValuation @relation(fields: [rentValuationId], references: [id], onDelete: Cascade)

  @@index([rentValuationId])
}

/// Loyer comparable (DVF / marché)
model ComparableRent {
  id               String @id @default(cuid())
  rentValuationId  String

  source          String // "DVF", "MANUAL", "AI_SEARCH", "CLAMEUR"
  sourceReference String?

  address      String
  city         String
  postalCode   String
  rentDate     DateTime // Date du loyer ou de la transaction
  annualRent   Float // Loyer annuel HT
  area         Float? // Surface (m²)
  rentPerSqm   Float?
  propertyType String // "BUREAUX", "HABITATION", "COMMERCIAL", "MIXTE"
  leaseType    String? // Type de bail
  distanceKm   Float? // Distance au bien

  relevanceScore   Float?
  relevanceComment String? @db.Text

  rentValuation RentValuation @relation(fields: [rentValuationId], references: [id], onDelete: Cascade)

  @@index([rentValuationId])
}

/// Rapport consolidé d'évaluation de loyer
model RentConsolidatedReport {
  id               String @id @default(cuid())
  rentValuationId  String @unique

  fileUrl  String?
  fileName String?

  reportContent Json

  generatedAt DateTime @default(now())
  generatedBy String

  rentValuation RentValuation @relation(fields: [rentValuationId], references: [id], onDelete: Cascade)
}

// ============================================================
// PHASE 10 — MODÈLES DE BAIL & NUMÉROTATION
// ============================================================

/// Modèle de bail — template réutilisable pour générer des baux PDF
model LeaseTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  name        String // Nom du modèle (ex: "Bail habitation standard")
  description String? @db.Text
  leaseType   LeaseType // Type de bail associé
  isDefault   Boolean   @default(false) // Modèle par défaut pour ce type
  isActive    Boolean   @default(true)

  // Contenu du modèle
  // Chaque section contient du texte avec des variables {{bailleur.nom}}, {{locataire.nom}}, etc.
  headerContent           String? @db.Text // En-tête / titre du bail
  partiesClause           String? @db.Text // Désignation des parties
  premisesClause          String? @db.Text // Désignation des locaux
  durationClause          String? @db.Text // Durée et renouvellement
  rentClause              String? @db.Text // Loyer et charges
  depositClause           String? @db.Text // Dépôt de garantie
  indexationClause        String? @db.Text // Clause de révision
  chargesClause           String? @db.Text // Répartition des charges
  useClause               String? @db.Text // Destination des locaux
  maintenanceClause       String? @db.Text // Entretien et réparations
  insuranceClause         String? @db.Text // Assurance
  terminationClause       String? @db.Text // Résiliation
  specialConditions       String? @db.Text // Conditions particulières
  signatureClause         String? @db.Text // Clause de signature

  // Métadonnées du modèle
  defaultDurationMonths   Int?    // Durée par défaut
  defaultPaymentFrequency PaymentFrequency?
  defaultBillingTerm      BillingTerm?
  defaultVatApplicable    Boolean?
  defaultVatRate          Float?
  defaultIndexType        IndexType?
  defaultDepositMonths    Int?    // Nombre de mois de loyer pour le dépôt

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  leases  Lease[]

  @@index([societyId])
  @@index([societyId, leaseType])
  @@unique([societyId, name])
}

// ============================================================
// PHASE 11 — TICKETING PORTAIL LOCATAIRE
// ============================================================

/// Ticket de demande locataire (portail → gestionnaire)
model Ticket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String
  tenantId  String

  // Identification
  ticketNumber String @unique // Ex: "TK-2026-0001"

  // Contenu
  subject     String
  description String  @db.Text
  category    TicketCategory
  priority    TicketPriority @default(NORMALE)
  status      TicketStatus   @default(OUVERT)

  // Localisation (pour maintenance)
  lotId    String? // Lot concerné (optionnel)
  location String? // Précision dans le lot (ex: "Salle de bain")

  // Fichiers joints
  attachmentUrls  Json? // string[] — URLs des pièces jointes
  attachmentPaths Json? // string[] — Chemins Supabase

  // Résolution
  resolvedAt  DateTime?
  resolvedBy  String?  // userId du gestionnaire
  closedAt    DateTime?
  closedBy    String?

  // Assignation
  assignedToId String? // userId du gestionnaire assigné

  // Relations
  society  Society        @relation(fields: [societyId], references: [id], onDelete: Cascade)
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([societyId])
  @@index([societyId, status])
  @@index([tenantId])
  @@index([ticketNumber])
}

/// Message dans un ticket (échange bidirectionnel)
model TicketMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  ticketId  String

  // Auteur
  authorType  String // "TENANT" ou "MANAGER"
  authorId    String // tenantId ou userId selon authorType
  authorName  String // Nom affiché

  // Contenu
  content String @db.Text

  // Fichiers joints
  attachmentUrls  Json? // string[]
  attachmentPaths Json? // string[]

  // Lecture
  isRead Boolean @default(false)

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([ticketId, createdAt])
}

// ============================================================
// PHASE 12 — GESTION TIERS (MANDAT DE GESTION)
// ============================================================

/// Compte-rendu de gestion reçu de l'agence
model ManagementReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String
  leaseId   String

  // Période et montants (remplis par l'IA ou manuellement)
  periodStart   DateTime
  periodEnd     DateTime
  grossRent     Float      // Loyer brut encaissé
  chargesAmount Float?     // Charges encaissées
  feeAmountHT   Float      // Honoraires HT déduits
  feeAmountTTC  Float      // Honoraires TTC déduits
  netTransfer   Float      // Montant net viré au propriétaire

  // Document source
  reportFileUrl         String?
  reportFileStoragePath String?

  // Analyse IA
  aiAnalyzed    Boolean  @default(false)
  aiRawResponse Json?
  aiConfidence  Float?   // Score de confiance 0-1

  // Rapprochement
  isReconciled        Boolean   @default(false)
  reconciledPaymentId String?
  reconciledAt        DateTime?

  notes String? @db.Text

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  lease   Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@index([leaseId])
  @@index([periodStart])
}

// ============================================================
// PHASE 13 — SYNDIC DE COPROPRIÉTÉ
// ============================================================

/// Copropriété gérée
model Copropriete {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  name            String          // Nom de la copropriété
  address         String          // Adresse complète
  city            String
  postalCode      String
  totalTantiemes  Int             // Total des tantièmes (ex: 1000, 10000)
  fiscalYearStart Int    @default(1)  // Mois de début exercice (1=janvier)
  siret           String?
  notes           String? @db.Text

  society    Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  lots       CoproLot[]
  budgets    CoproBudget[]
  assemblies CoproAssembly[]

  @@index([societyId])
}

/// Lot de copropriété avec tantièmes
model CoproLot {
  id            String @id @default(cuid())
  coproprieteId String
  lotNumber     String       // Numéro du lot
  ownerName     String       // Nom du copropriétaire
  ownerEmail    String?
  tantiemes     Int          // Tantièmes du lot
  description   String?      // Description (appartement, cave, parking...)
  floor         String?
  area          Float?       // Surface en m²

  copropriete Copropriete @relation(fields: [coproprieteId], references: [id], onDelete: Cascade)
  votes       CoproVote[]

  @@index([coproprieteId])
}

/// Budget prévisionnel de copropriété
model CoproBudget {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  coproprieteId String

  year          Int            // Année du budget
  status        CoproBudgetStatus @default(DRAFT)
  totalAmount   Float          // Montant total du budget
  lines         Json           // Array de { category, label, amount, description }
  notes         String?  @db.Text
  approvedAt    DateTime?
  approvedByAssemblyId String?

  copropriete Copropriete @relation(fields: [coproprieteId], references: [id], onDelete: Cascade)

  @@unique([coproprieteId, year])
  @@index([coproprieteId])
}

enum CoproBudgetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

/// Assemblée Générale de copropriété
model CoproAssembly {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  coproprieteId String

  title         String
  date          DateTime
  type          CoproAssemblyType @default(ORDINAIRE)
  status        CoproAssemblyStatus @default(PLANNED)
  location      String?        // Lieu ou lien visio
  isOnline      Boolean  @default(false)
  quorumRequired Float   @default(0.5) // Pourcentage tantièmes

  // Convocation
  convocationSentAt DateTime?
  convocationFileUrl String?

  // PV
  pvFileUrl     String?
  pvApprovedAt  DateTime?

  notes         String?  @db.Text

  copropriete Copropriete       @relation(fields: [coproprieteId], references: [id], onDelete: Cascade)
  resolutions CoproResolution[]

  @@index([coproprieteId])
  @@index([date])
}

enum CoproAssemblyType {
  ORDINAIRE
  EXTRAORDINAIRE
  MIXTE
}

enum CoproAssemblyStatus {
  PLANNED
  CONVOCATION_SENT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Résolution d'AG
model CoproResolution {
  id         String @id @default(cuid())
  assemblyId String

  number     Int            // Numéro de résolution
  title      String
  description String? @db.Text
  majority   CoproMajority  @default(SIMPLE) // Type de majorité requise
  status     CoproResolutionStatus @default(PENDING)

  // Résultats
  votesFor     Int @default(0)   // Tantièmes pour
  votesAgainst Int @default(0)   // Tantièmes contre
  abstentions  Int @default(0)   // Tantièmes abstention

  assembly CoproAssembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  votes    CoproVote[]

  @@index([assemblyId])
}

enum CoproMajority {
  SIMPLE          // Art. 24 — majorité simple des présents
  ABSOLUE         // Art. 25 — majorité absolue de tous
  DOUBLE          // Art. 26 — double majorité (2/3 tantièmes)
  UNANIMITE       // Unanimité
}

enum CoproResolutionStatus {
  PENDING
  ADOPTED
  REJECTED
  DEFERRED
}

/// Vote individuel sur une résolution
model CoproVote {
  id           String @id @default(cuid())
  resolutionId String
  lotId        String

  vote         CoproVoteChoice
  proxy        Boolean @default(false)  // Vote par procuration
  proxyName    String?                  // Nom du mandataire

  resolution CoproResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  lot        CoproLot        @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([resolutionId, lotId])
  @@index([resolutionId])
}

enum CoproVoteChoice {
  POUR
  CONTRE
  ABSTENTION
}

// ============================================================
// PHASE 14 — LOCATION SAISONNIÈRE
// ============================================================

/// Bien en location saisonnière
model SeasonalProperty {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String
  lotId     String?  // Optionnel: lié à un lot existant

  name          String       // Nom commercial (ex: "Villa Tropicale")
  description   String? @db.Text
  address       String
  city          String
  postalCode    String
  country       String  @default("France")
  propertyType  SeasonalPropertyType @default(APARTMENT)
  capacity      Int          // Nombre de personnes max
  bedrooms      Int
  bathrooms     Int
  area          Float?       // Surface m²
  amenities     Json?        // Array de string (piscine, wifi, parking...)
  photos        Json?        // Array de { url, caption }
  checkInTime   String  @default("15:00")
  checkOutTime  String  @default("11:00")
  minStay       Int     @default(1)    // Nombre de nuits minimum
  isActive      Boolean @default(true)

  // OTA / Channel Manager
  otaConnections Json?  // { airbnb?: { listingId }, booking?: { propertyId }, ... }
  icalUrl        String? // URL iCal pour synchronisation

  society    Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  bookings   SeasonalBooking[]
  pricing    SeasonalPricing[]
  blockedDates SeasonalBlockedDate[]

  @@index([societyId])
  @@index([lotId])
}

enum SeasonalPropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  ROOM
  GITE
  CHALET
}

/// Réservation saisonnière
model SeasonalBooking {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  propertyId String

  guestName    String
  guestEmail   String?
  guestPhone   String?
  guestCount   Int    @default(1)
  checkIn      DateTime
  checkOut     DateTime
  nights       Int
  totalPrice   Float
  cleaningFee  Float   @default(0)
  platformFee  Float   @default(0)
  netRevenue   Float          // Prix total - frais plateforme
  status       SeasonalBookingStatus @default(CONFIRMED)
  source       String?        // "direct", "airbnb", "booking", etc.
  externalId   String?        // ID sur la plateforme OTA
  notes        String? @db.Text

  property SeasonalProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([checkIn])
  @@index([checkOut])
}

enum SeasonalBookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

/// Tarification saisonnière (périodes)
model SeasonalPricing {
  id         String   @id @default(cuid())
  propertyId String

  name       String        // "Haute saison", "Basse saison", "Noël"...
  startDate  DateTime
  endDate    DateTime
  pricePerNight Float
  weeklyDiscount Float?   // % de réduction semaine
  monthlyDiscount Float?  // % de réduction mois

  property SeasonalProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([startDate, endDate])
}

/// Dates bloquées (indisponibilités)
model SeasonalBlockedDate {
  id         String   @id @default(cuid())
  propertyId String

  startDate  DateTime
  endDate    DateTime
  reason     String?

  property SeasonalProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// ============================================================
// PHASE 15 — CRM / PIPELINE CANDIDATURES
// ============================================================

/// Pipeline de candidatures personnalisable
model CandidatePipeline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  societyId String

  name   String   // "Pipeline standard", "Location bureaux"...
  stages Json     // Array de { id, name, order, color }

  society    Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  candidates Candidate[]

  @@index([societyId])
}

/// Candidature locataire
model Candidate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String
  pipelineId String?
  lotId      String?  // Lot visé

  // Identité
  firstName  String
  lastName   String
  email      String?
  phone      String?
  company    String?

  // Pipeline
  stageId    String?          // ID du stage dans pipeline.stages
  score      Int?             // Score 0-100
  source     String?          // "site", "leboncoin", "seloger", "recommandation"...
  status     CandidateStatus @default(NEW)

  // Dossier
  monthlyIncome  Float?
  guarantorName  String?
  desiredMoveIn  DateTime?
  notes          String? @db.Text
  documents      Json?   // Array de { name, url }
  tags           Json?   // Array de string

  society  Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  pipeline CandidatePipeline? @relation(fields: [pipelineId], references: [id])
  activities CandidateActivity[]

  @@index([societyId])
  @@index([pipelineId])
  @@index([status])
}

enum CandidateStatus {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  VISIT_DONE
  DOSSIER_RECEIVED
  DOSSIER_VALIDATED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

/// Historique d'activité sur une candidature
model CandidateActivity {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  candidateId String

  type    CandidateActivityType
  content String?  @db.Text   // Note, message, détail...
  userId  String?              // Qui a fait l'action

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([createdAt])
}

enum CandidateActivityType {
  NOTE
  EMAIL_SENT
  CALL
  VISIT
  DOCUMENT_RECEIVED
  STATUS_CHANGE
  SCORE_UPDATE
}

// ============================================================
// PHASE 16 — WORKFLOWS VISUELS
// ============================================================

/// Workflow automatisé
model Workflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  name        String
  description String?
  isActive    Boolean @default(false)
  trigger     Json    // { type: "event"|"schedule"|"manual", config: {...} }
  steps       Json    // Array de { id, type, config, position, connections }
  lastRunAt   DateTime?
  runCount    Int     @default(0)

  society  Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  runs     WorkflowRun[]

  @@index([societyId])
}

/// Exécution d'un workflow
model WorkflowRun {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  workflowId String

  status     WorkflowRunStatus @default(RUNNING)
  triggeredBy String?           // userId ou "system"
  startedAt  DateTime @default(now())
  completedAt DateTime?
  error      String?  @db.Text
  stepResults Json?   // Array de { stepId, status, output, duration }

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([createdAt])
}

enum WorkflowRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
