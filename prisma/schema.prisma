// ============================================================
// TRANSVERSAL — DOCUMENTS ET GED
// ============================================================

/// Document générique (GED)
model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  societyId String

  // Polymorphisme via champs nullable
  buildingId String?
  lotId      String?
  leaseId    String?
  tenantId   String?

  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  category    String? // titre_propriete, reglement_copro, plan, avenant, etc.
  description String?
  expiresAt   DateTime?

  // GED IA
  storagePath  String?   // chemin brut Supabase Storage (stable)
  aiSummary    String?   @db.Text  // resume genere par Claude
  aiTags       String[]            // tags extraits automatiquement
  aiMetadata   Json?               // metadonnees cles (loyer, dates, noms...)
  aiAnalyzedAt DateTime?           // date derniere analyse IA
  aiStatus     String?             // pending | done | error

  society           Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  building          Building?         @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  lot               Lot?              @relation(fields: [lotId], references: [id], onDelete: SetNull)
  lease             Lease?            @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  tenant            Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  dataroomDocuments DataroomDocument[]

  @@index([societyId])
  @@index([buildingId])
  @@index([lotId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([expiresAt])
  @@index([aiStatus])
}

// ============================================================
// RGPD
// ============================================================

/// Registre des traitements RGPD
model DataProcessingRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purpose        String // Finalité du traitement
  dataCategories String[] // Catégories de données
  legalBasis     String // Base légale
  recipients     String[] // Destinataires
  retentionDays  Int // Durée de conservation en jours
  description    String?  @db.Text
  isActive       Boolean  @default(true)
}

/// Demande d'exercice de droits RGPD
model GdprRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societyId String
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  requesterEmail String
  requesterName  String
  requestType    String // access, rectification, deletion, portability
  status         String    @default("pending") // pending, processing, completed, refused
  processedAt    DateTime?
  processedBy    String?
  notes          String?   @db.Text

  @@index([societyId])
  @@index([status])
  @@index([requesterEmail])
}

// ============================================================
// MODULE EMPRUNTS — GESTION DES PRÊTS ET AMORTISSEMENTS
// ============================================================

/// Emprunt immobilier lié à un immeuble
model Loan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  // Bien financé (optionnel — peut être un emprunt global)
  buildingId String?

  // Identité du prêt
  label    String // Libellé ex: "Prêt BNP — immeuble Centre"
  lender   String // Établissement prêteur
  loanType LoanType   @default(AMORTISSABLE)
  status   LoanStatus @default(EN_COURS)

  // Paramètres financiers
  amount         Float // Capital emprunté (€)
  interestRate   Float // Taux annuel nominal (%)
  insuranceRate  Float @default(0) // Taux assurance annuel (%)
  durationMonths Int // Durée en mois

  // Dates
  startDate DateTime
  endDate   DateTime // Calculé à la création

  // Valeur nette
  purchaseValue Float? // Valeur d'acquisition du bien (pour calcul valeur nette)

  // Notes
  notes String? @db.Text

  society           Society                @relation(fields: [societyId], references: [id], onDelete: Cascade)
  building          Building?              @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  amortizationLines LoanAmortizationLine[]

  @@index([societyId])
  @@index([societyId, status])
  @@index([buildingId])
}

/// Ligne du tableau d'amortissement
model LoanAmortizationLine {
  id     String @id @default(cuid())
  loanId String

  period           Int // Numéro d'échéance (1, 2, …, n)
  dueDate          DateTime // Date d'échéance
  principalPayment Float // Capital remboursé
  interestPayment  Float // Intérêts payés
  insurancePayment Float    @default(0) // Assurance
  totalPayment     Float // Mensualité totale
  remainingBalance Float // Capital restant dû après cette échéance

  isPaid Boolean   @default(false)
  paidAt DateTime?

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([loanId, dueDate])
}

// ============================================================
// MODULE COMPTABILITÉ — PRÉVISIONNEL / BUDGET
// ============================================================

/// Ligne budgétaire prévisionnelle par compte et période
model BudgetLine {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  year      Int // Exercice comptable
  month     Int? // null = budget annuel, 1-12 = mensuel
  accountId String // Compte comptable lié

  budgetAmount Float // Montant prévisionnel (€)
  label        String? // Commentaire optionnel

  society Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  account AccountingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([societyId, year, month, accountId])
  @@index([societyId])
  @@index([societyId, year])
}

/// Consentement collecté
model Consent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email     String
  purpose   String // contact_form, newsletter, visit_request
  ipAddress String?
  userAgent String?
  isGranted Boolean   @default(true)
  revokedAt DateTime?

  @@index([email, purpose])
}

// ============================================================
// PHASE 4.2 — SIGNATURES DOCUSIGN
// ============================================================

enum SignatureStatus {
  SENT
  DELIVERED
  COMPLETED
  DECLINED
  VOIDED
}

enum SignatureDocumentType {
  BAIL
  ETAT_DES_LIEUX
  MANDAT
  AUTRE
}

/// Demande de signature electronique DocuSign
model SignatureRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  societyId String

  envelopeId     String                @unique // ID enveloppe DocuSign
  status         SignatureStatus
  documentType   SignatureDocumentType
  documentId     String? // ID du document lié (bail, etc.)
  documentName   String
  signerEmail    String
  signerName     String
  signerClientId String? // Pour signature embarquée (embedded)
  subject        String?
  message        String?

  // Lien optionnel vers le bail
  leaseId String?

  // Dates de statut
  signedAt      DateTime?
  voidedAt      DateTime?
  voidReason    String?
  declinedAt    DateTime?
  declineReason String?

  // Document signé
  signedDocumentUrl         String?
  signedDocumentStoragePath String?

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  lease   Lease?  @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([societyId])
  @@index([societyId, status])
  @@index([leaseId])
}

