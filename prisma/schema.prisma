// ============================================================
// SCHÉMA PRISMA COMPLET — APPLICATION GESTION IMMOBILIÈRE
// Couvre les Phases 1 à 9
// Multi-tenant strict : chaque entité scopée par societyId
// ============================================================

generator client {
  output   = "../src/generated/prisma/client"
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN_SOCIETE
  GESTIONNAIRE
  COMPTABLE
  LECTURE
}

enum LegalForm {
  SCI
  SARL
  SAS
  SA
  EURL
  SASU
  SNC
  AUTRE
  PERSONNE_PHYSIQUE
}

enum TaxRegime {
  IS
  IR
}

enum VatRegime {
  TVA
  FRANCHISE
}

enum BuildingType {
  BUREAU
  COMMERCE
  MIXTE
  ENTREPOT
}

enum LotType {
  LOCAL_COMMERCIAL
  BUREAUX
  LOCAL_ACTIVITE
  RESERVE
  PARKING
  CAVE
  TERRASSE
  ENTREPOT
  APPARTEMENT
}

enum LotStatus {
  OCCUPE
  VACANT
  EN_TRAVAUX
  RESERVE
}

enum LeaseType {
  // Baux d'habitation
  HABITATION         // Bail vide — loi du 6 juillet 1989 (3 ans / 6 ans)
  MEUBLE             // Bail meublé — loi ALUR (1 an, 9 mois étudiant)
  ETUDIANT           // Bail étudiant meublé (9 mois, non renouvelable)
  MOBILITE           // Bail mobilité — loi ELAN (1 à 10 mois, non renouvelable)
  COLOCATION         // Bail colocation (vide ou meublée)
  SAISONNIER         // Location saisonnière (< 90 jours)
  LOGEMENT_FONCTION  // Logement de fonction / accessoire au contrat de travail
  ANAH               // Convention ANAH — loyer maîtrisé
  CIVIL              // Bail civil (Code civil, résidence secondaire, etc.)
  GLISSANT           // Bail glissant (association → locataire, insertion sociale)
  SOUS_LOCATION      // Sous-location autorisée

  // Baux commerciaux et professionnels
  COMMERCIAL_369     // Bail commercial 3/6/9 ans
  DEROGATOIRE        // Bail dérogatoire (< 3 ans)
  PRECAIRE           // Convention d'occupation précaire
  BAIL_PROFESSIONNEL // Bail professionnel (6 ans)
  MIXTE              // Bail mixte habitation + professionnel

  // Baux longs / fonciers
  EMPHYTEOTIQUE      // Bail emphytéotique (18 à 99 ans)
  CONSTRUCTION       // Bail à construction
  REHABILITATION     // Bail à réhabilitation
  BRS                // Bail réel solidaire (OFS)

  // Bail rural
  RURAL              // Bail rural / agricole (9 ans min.)
}

enum LeaseStatus {
  EN_COURS
  RESILIE
  RENOUVELE
  EN_NEGOCIATION
  CONTENTIEUX
}

enum PaymentFrequency {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
}

enum BillingTerm {
  ECHU // Terme échu — paiement en fin de période (ex: loyer de janvier payé le 1er février)
  A_ECHOIR // Terme à échoir — paiement en début de période (ex: loyer de janvier payé le 1er janvier)
}

enum IndexType {
