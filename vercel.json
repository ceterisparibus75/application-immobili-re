{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/ai-retry",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/generate-drafts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/insurance-reminder",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/invoice-reminder",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/lease-alerts",
