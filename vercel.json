    },
    {
      "path": "/api/cron/rent-revisions",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/run-workflows",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/send-reports",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sync-bank",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-einvoices",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-indices",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/cron/sync-subscriptions",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/data-retention-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/document-alerts",
      "schedule": "0 8 * * 1"
    }
