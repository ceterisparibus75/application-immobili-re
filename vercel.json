{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps --force",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/generate-drafts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/daily-maintenance",
      "schedule": "15 8 * * *"
    }
  ]
}
