{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps --force",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/insurance-reminder",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/invoice-reminder",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/sync-bank",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-indices",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/cron/rent-revisions",
      "schedule": "0 8 1 * *"
    }
  ]
}
