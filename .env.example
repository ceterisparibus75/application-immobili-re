# ==============================================================================
# VARIABLES D'ENVIRONNEMENT — MYGESTIA
# ==============================================================================
# Copiez ce fichier vers .env.local et remplissez les valeurs.
# Ne commitez JAMAIS .env.local dans git (déjà exclu par .gitignore).
# En production, configurez ces variables dans Vercel → Settings → Environment Variables.
# ==============================================================================

# ==============================================================================
# BASE DE DONNÉES (Supabase PostgreSQL)
# ==============================================================================
# ⚠️ DATABASE_URL doit pointer vers le POOLER PgBouncer (port 6543, ?pgbouncer=true)
#    pour éviter la saturation des connexions en serverless (Vercel).
#    DIRECT_URL utilise la connexion directe (port 5432) uniquement pour les migrations.
#
# Dans Supabase : Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres"

# ==============================================================================
# SUPABASE (Storage, Auth)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""            # Clé publique (Settings → API → anon key)
SUPABASE_SERVICE_ROLE_KEY=""                # ⚠️ JAMAIS exposée côté client (Settings → API → service_role)

# ==============================================================================
# AUTHENTIFICATION (NextAuth v5)
# ==============================================================================
AUTH_SECRET=""          # Générer : openssl rand -base64 32
AUTH_URL="http://localhost:3000"            # En production : https://votre-domaine.com

# ==============================================================================
# CHIFFREMENT (données bancaires IBAN/BIC, secrets 2FA)
# ==============================================================================
ENCRYPTION_KEY=""       # 32 bytes en base64 — générer : openssl rand -base64 32

# ==============================================================================
# EMAILS (Resend)
# ==============================================================================
RESEND_API_KEY=""                           # https://resend.com → API Keys
RESEND_WEBHOOK_SECRET=""                    # Secret Svix/Resend pour /api/webhooks/email-inbound
EMAIL_FROM="gestion@votredomaine.fr"        # Adresse expéditeur vérifiée dans Resend

# ==============================================================================
# API INSEE (indices IRL/ILC/ILAT)
# ==============================================================================
INSEE_API_KEY=""                            # https://api.insee.fr → Mon compte
INSEE_API_SECRET=""

# ==============================================================================
# CONFIGURATION APPLICATIVE
# ==============================================================================
NEXT_PUBLIC_APP_NAME="MyGestia"
CRON_SECRET=""          # Secret partagé pour protéger les routes /api/cron/*

# ==============================================================================
# MONITORING (Sentry) — Optionnel
# ==============================================================================
# sendDefaultPii est désactivé dans sentry.server.config.ts — ne jamais le réactiver.
# SENTRY_DSN       : variable serveur uniquement (non exposée au client)
# NEXT_PUBLIC_SENTRY_DSN : fallback pour le client Next.js (même DSN en général)
SENTRY_DSN=""                               # Sentry → Settings → Client Keys → DSN (serveur)
NEXT_PUBLIC_SENTRY_DSN=""                   # Sentry → Settings → Client Keys → DSN (client)
SENTRY_ORG=""                               # Slug organisation Sentry
SENTRY_PROJECT=""                           # Slug projet Sentry
SENTRY_TRACES_SAMPLE_RATE="0.05"           # Taux d'échantillonnage traces (0.05 = 5% en prod)
SENTRY_UPLOAD_SOURCE_MAPS="false"           # true uniquement hors Vercel (Vercel le fait automatiquement)

# ==============================================================================
# INTELLIGENCE ARTIFICIELLE — Optionnel (dégradation gracieuse sans ces clés)
# ==============================================================================
ANTHROPIC_API_KEY=""                        # https://console.anthropic.com → API Keys
OPENAI_API_KEY=""                           # https://platform.openai.com → API Keys
GOOGLE_AI_API_KEY=""                        # https://aistudio.google.com → API Keys
MISTRAL_API_KEY=""                          # https://console.mistral.ai → API Keys
BRAINTRUST_API_KEY=""                       # Observabilité LLM — optionnel
BRAINTRUST_PROJECT_ID=""

# ==============================================================================
# OPEN BANKING — Optionnel
# ==============================================================================
# GoCardless (PSD2 Open Banking Europe)
GOCARDLESS_SECRET_ID=""                     # GoCardless → Developers → Access tokens
GOCARDLESS_SECRET_KEY=""
GOCARDLESS_PAYMENTS_WEBHOOK_SECRET=""       # Pour valider les webhooks GoCardless

# Powens / Budget Insight
POWENS_DOMAIN=""                            # ex: sync.bankin.com
POWENS_CLIENT_ID=""
POWENS_CLIENT_SECRET=""

# Qonto
QONTO_CLIENT_ID=""
QONTO_CLIENT_SECRET=""

# ==============================================================================
# PAIEMENTS ET ABONNEMENTS (Stripe) — Optionnel
# ==============================================================================
STRIPE_SECRET_KEY=""                        # https://dashboard.stripe.com → Developers → API keys
STRIPE_WEBHOOK_SECRET=""                    # Stripe → Webhooks → Signing secret
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_YEARLY=""

# ==============================================================================
# SIGNATURE ÉLECTRONIQUE (DocuSign) — ENTERPRISE uniquement
# ==============================================================================
DOCUSIGN_API_KEY=""                         # DocuSign → Apps & Keys → Integration Key
DOCUSIGN_ACCOUNT_ID=""                      # DocuSign → Account → API Account ID
DOCUSIGN_USER_ID=""                         # DocuSign → Apps & Keys → User ID
DOCUSIGN_PRIVATE_KEY=""                     # Clé RSA en base64 (JWT Grant)
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"  # demo ou na1.docusign.net (prod)
DOCUSIGN_AUTH_URL="https://account-d.docusign.com"     # account-d (demo) ou account (prod)
DOCUSIGN_WEBHOOK_SECRET=""                  # Pour valider les webhooks DocuSign

# ==============================================================================
# FACTURATION ÉLECTRONIQUE B2G — Chorus Pro (réforme sect. public)
# ==============================================================================
# Créer un compte technique sur portail.chorus-pro.gouv.fr → Espace EDI & API
PISTE_CLIENT_ID=""                          # PISTE → Mon compte → Applications
PISTE_CLIENT_SECRET=""
PISTE_ENV="sandbox"                         # "sandbox" | "production"
CHORUS_PRO_ENV="sandbox"                    # "sandbox" | "production"
CHORUS_PRO_TECH_ACCOUNT=""                  # ex: TECH_1_xxxxx@cpro.fr
CHORUS_PRO_TECH_PASSWORD=""
CHORUS_PRO_TECH_USER_ID=""                  # ID numérique interne Chorus Pro

# ==============================================================================
# FACTURATION ÉLECTRONIQUE B2B — Plateforme Agréée (réforme sept. 2026)
# ==============================================================================
# Contrat direct avec une PA certifiée DGFiP (ex. SUPER PDP, Chorus Pro PA, etc.)
PA_API_BASE_URL=""                          # ex: https://api.superpdp.tech
PA_API_KEY=""                               # Bearer token fourni par la PA (si pas OAuth2)
PA_AUTH_TOKEN_URL=""                        # ex: https://api.superpdp.tech/oauth2/token
PA_AUTH_CLIENT_ID=""
PA_AUTH_CLIENT_SECRET=""
PA_OAUTH_AUTHORIZE_URL=""                   # ex: https://api.superpdp.tech/oauth2/authorize
PA_MANDATAIRE_SIRET=""                      # ★ SIRET MTG Holding — active le Mode B (SC mandataire)

# ==============================================================================
# SUPPORT UTILISATEUR — Optionnel
# ==============================================================================
NEXT_PUBLIC_ZENDESK_KEY=""                  # Zendesk → Admin → Widget → Script key
